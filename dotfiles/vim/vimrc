" Vim configuration generated from the useful parts of old/vim_config.vim.
" Keep this file standalone: do not depend on ~/.vim_runtime.

" Plugin management ---------------------------------------------------------
let s:plug_path = expand('~/.vim/autoload/plug.vim')

if empty(glob(s:plug_path))
    silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
                \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
endif

if !empty(glob(s:plug_path))
    autocmd VimEnter * if len(filter(values(g:plugs), '!isdirectory(v:val.dir)')) | PlugInstall --sync | source $MYVIMRC | endif

    call plug#begin('~/.vim/plugged')

    " Navigation and project workflow.
    Plug 'junegunn/fzf', { 'dir': '~/.fzf', 'do': './install --all' }
    Plug 'junegunn/fzf.vim'
    Plug 'preservim/nerdtree'
    Plug 'preservim/nerdcommenter'
    Plug 'majutsushi/tagbar'
    Plug 'jlanzarotta/bufexplorer'

    " Git and editing helpers.
    Plug 'tpope/vim-fugitive'
    Plug 'tpope/vim-surround'
    Plug 'mhinz/vim-signify'
    Plug 'vim-airline/vim-airline'
    Plug 'vim-airline/vim-airline-themes'

    " Language support.
    Plug 'fatih/vim-go', { 'do': ':GoUpdateBinaries' }
    Plug 'hashivim/vim-terraform'
    Plug 'pangloss/vim-javascript'
    Plug 'mxw/vim-jsx'
    Plug 'plasticboy/vim-markdown'

    " Color schemes.
    Plug 'morhetz/gruvbox'
    Plug 'drewtempelmeyer/palenight.vim'

    call plug#end()
endif

" General settings ----------------------------------------------------------
set encoding=utf-8
scriptencoding utf-8

filetype plugin indent on
syntax enable

set autoindent
set autoread
set backspace=eol,start,indent
set completeopt=menuone,noinsert,noselect
set expandtab
set hidden
set history=500
set ignorecase
set incsearch
set laststatus=2
set lazyredraw
set list
set listchars=tab:>-,trail:.,extends:>,precedes:<
set magic
set noerrorbells
set noswapfile
set nowrap
set number
set relativenumber
set ruler
set shiftwidth=4
set showmatch
set smartcase
set smartindent
set smarttab
set softtabstop=4
set splitbelow
set splitright
set tabstop=4
set title
set updatetime=300
set wildignorecase
set wildmode=list:longest,full
set wildignore=*.o,*~,*.pyc
set wildignore+=*/.git/*,*/.hg/*,*/.svn/*,*/.DS_Store
set wildignore+=*/node_modules/*,*/.venv/*,*/dist/*,*/build/*

if has('clipboard')
    if has('unnamedplus')
        set clipboard=unnamedplus
    else
        set clipboard=unnamed
    endif
endif

if has('persistent_undo')
    silent! call mkdir(expand('~/.vim/undo'), 'p')
    set undodir=~/.vim/undo
    set undofile
endif

" UI ------------------------------------------------------------------------
set background=dark
set colorcolumn=81
set cursorline
set foldcolumn=1
set mat=2

try
    colorscheme palenight
catch
    try
        colorscheme gruvbox
    catch
    endtry
endtry

if has('gui_running')
    if has('mac') || has('macunix')
        set guifont=IBM\ Plex\ Mono:h14,Hack:h14,Source\ Code\ Pro:h15,Menlo:h15
    endif
    set guioptions-=r
    set guioptions-=R
    set guioptions-=l
    set guioptions-=L
endif

" Leader and core mappings --------------------------------------------------
let mapleader = ','

nnoremap <space> zz
nnoremap <leader>w :w!<cr>
nnoremap <silent> <leader><cr> :nohlsearch<cr>
nnoremap <leader>c :nohlsearch<cr>
command W w !sudo tee % > /dev/null

" Keep next/previous search results centered.
nnoremap n nzzzv
nnoremap N Nzzzv

" Window and buffer navigation.
nnoremap <C-j> <C-W>j
nnoremap <C-k> <C-W>k
nnoremap <C-h> <C-W>h
nnoremap <C-l> <C-W>l
nnoremap <leader>v :vsplit<cr>
nnoremap <leader>s :split<cr>
nnoremap <leader>q :close<cr>
nnoremap <leader>l :bnext<cr>
nnoremap <leader>h :bprevious<cr>
nnoremap <leader>ba :bufdo bd<cr>

" Tabs.
nnoremap <leader>tn :tabnew<cr>
nnoremap <leader>to :tabonly<cr>
nnoremap <leader>tc :tabclose<cr>
nnoremap <leader>tm :tabmove
nnoremap <leader>t<leader> :tabnext<cr>

" Edit near the current file and change cwd to current file directory.
nnoremap <leader>te :tabedit <c-r>=expand("%:p:h")<cr>/
nnoremap <leader>cd :cd %:p:h<cr>:pwd<cr>

" Remap 0 to first non-blank character.
nnoremap 0 ^

" Move selected lines.
nnoremap <M-j> mz:m+<cr>`z
nnoremap <M-k> mz:m-2<cr>`z
vnoremap <M-j> :m'>+<cr>`<my`>mzgv`yo`z
vnoremap <M-k> :m'<-2<cr>`>my`<mzgv`yo`z

if has('mac') || has('macunix')
    nnoremap <D-j> <M-j>
    nnoremap <D-k> <M-k>
    vnoremap <D-j> <M-j>
    vnoremap <D-k> <M-k>
endif

" Spell checking.
nnoremap <leader>ss :setlocal spell!<cr>
nnoremap <leader>sn ]s
nnoremap <leader>sp [s
nnoremap <leader>sa zg
nnoremap <leader>s? z=

iabbrev xdate <c-r>=strftime("%Y-%m-%d %H:%M:%S")<cr>

" Autocommands --------------------------------------------------------------
augroup user_config
    autocmd!
    autocmd BufReadPost * if line("'\"") > 1 && line("'\"") <= line("$") | execute "normal! g'\"" | endif
    autocmd BufWritePre * call <SID>clean_extra_spaces()
    autocmd FileType gitcommit setlocal spell textwidth=80
    autocmd FileType markdown setlocal spell
    autocmd FileType go setlocal noexpandtab shiftwidth=4 softtabstop=4 tabstop=4
    autocmd FileType make setlocal noexpandtab shiftwidth=2 softtabstop=2 tabstop=2
    autocmd FileType sh setlocal noexpandtab shiftwidth=2 softtabstop=2 tabstop=2
    autocmd FileType css,html,javascript,json,less,proto,ruby,sql,yaml setlocal expandtab shiftwidth=2 softtabstop=2 tabstop=2
    autocmd FileType python,vim,cpp,markdown setlocal expandtab shiftwidth=4 softtabstop=4 tabstop=4
augroup END

" Plugin configuration ------------------------------------------------------
let g:airline#extensions#tabline#enabled = 1
let g:airline#extensions#tabline#show_tabs = 0
let g:airline_powerline_fonts = 0

let g:signify_sign_add = '+'
let g:signify_sign_delete = '-'
let g:signify_sign_change = '~'

nnoremap <C-f> :Files<cr>
nnoremap <leader>ag :Rg<space>

let g:NERDTreeWinPos = 'left'
let g:NERDTreeWinSize = 35
let g:NERDTreeShowHidden = 1
let g:NERDTreeChDirMode = 2
let g:NERDTreeIgnore = [
    \ '\~$',
    \ '\.pyc$',
    \ '^\.DS_Store$',
    \ '^node_modules$',
    \ '^__pycache__$'
    \]
nnoremap <leader>nn :NERDTreeToggle<cr>
nnoremap <leader>nf :NERDTreeFind<cr>
autocmd user_config BufEnter * if winnr('$') == 1 && exists('b:NERDTree') && b:NERDTree.isTabTree() | quit | endif

nnoremap <F3> :TagbarToggle<cr>

let g:vim_markdown_folding_disabled = 1
let g:vim_markdown_toc_autofit = 1

let g:terraform_fmt_on_save = 1
let g:terraform_align = 1

let g:go_fmt_command = 'goimports'
let g:go_highlight_types = 1
let g:go_highlight_fields = 1
let g:go_highlight_functions = 1
let g:go_highlight_methods = 1
let g:go_highlight_structs = 1
let g:go_highlight_operators = 1
let g:go_highlight_build_constraints = 1
let g:go_highlight_extra_types = 1
let g:go_auto_type_info = 1
let g:go_auto_sameids = 1
let g:go_list_type = 'quickfix'
let g:go_test_show_name = 1

autocmd user_config FileType go nnoremap <buffer> <F9> :GoCoverageToggle -short<cr>
autocmd user_config FileType go nnoremap <buffer> <F10> :GoTest -short<cr>
autocmd user_config FileType go nnoremap <buffer> <F12> <Plug>(go-def)
autocmd user_config FileType go nnoremap <buffer> <leader>ga <Plug>(go-alternate-edit)
autocmd user_config FileType go nnoremap <buffer> <leader>gah <Plug>(go-alternate-split)
autocmd user_config FileType go nnoremap <buffer> <leader>gav <Plug>(go-alternate-vertical)
autocmd user_config FileType go nnoremap <buffer> <leader>gd <Plug>(go-def)
autocmd user_config FileType go nnoremap <buffer> <leader>gD <Plug>(go-doc)

" Helper functions ----------------------------------------------------------
function! s:clean_extra_spaces() abort
    let l:save_cursor = getpos('.')
    let l:old_query = getreg('/')
    silent! %s/\s\+$//e
    call setpos('.', l:save_cursor)
    call setreg('/', l:old_query)
endfunction
